# PolicyIQ Environment Configuration
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────
# Already configured in database.py - update there if needed

# ── SMTP Email (Gmail) ────────────────────────────────────────────────────
# To enable password reset emails:
# 1. Go to your Google Account > Security > 2-Step Verification
# 2. At the bottom, click "App passwords"
# 3. Create an app password for "Mail" on "Windows Computer"
# 4. Paste the 16-character app password below (NOT your Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# ── Frontend URL ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Google OAuth2 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

