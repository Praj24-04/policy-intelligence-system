# PolicyIQ Environment Configuration
# Copy this to .env and fill in your values for local development/production.

# ── Database Connection (PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/policy_db

# ── Security & Authentication ──────────────────────────────────────────────
# Generate a secure random 64-character hex key using: openssl rand -hex 32
JWT_SECRET_KEY=generate_a_random_hex_key_here
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=INFO

# ── SMTP Email (Gmail) ────────────────────────────────────────────────────
# To enable password reset emails:
# 1. Go to your Google Account > Security > 2-Step Verification
# 2. At the bottom, click "App passwords"
# 3. Create an app password for "Mail" on "Windows Computer"
# 4. Paste the 16-character app password below (NOT your Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# ── Frontend URL ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Google OAuth2 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Anthropic API Key (AI Policy Generator) ────────────────────────────────
# Get this from Anthropic console to enable AI policy drafts
ANTHROPIC_API_KEY=your-anthropic-api-key
